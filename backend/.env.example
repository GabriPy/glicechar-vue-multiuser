# ── Gluroo API ──────────────────────────────────────────
GLUROO_API_SECRET_TOKEN=il_tuo_token_qui
GLUROO_API_SECRET_HEADER=il_tuo_header_sha1_qui
GLUROO_BASE_URL=https://aaa1.ns.gluroo.com

# ── MySQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=glucoview
DB_PASSWORD=password_sicura
DB_NAME=glucoview

# ── Server ───────────────────────────────────────────────
PORT=3001

# URL pubblico del tuo server (usato dal frontend per le API)
# Con Cloudflare Tunnel usa il dominio pubblico, NON localhost
PUBLIC_API_URL=https://ghibiri.it/api

# Ogni quanti minuti sincronizzare i dati da Gluroo
POLL_INTERVAL_MINUTES=5
