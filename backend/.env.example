# 💉 GliceChart v1.2.0 - Environment Configuration Example

# ── MySQL Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=nomeutente_db
DB_PASSWORD=password_db
DB_NAME=nome_db

# ── Authentication (JWT) ──────────────────────────────────
# Genera stringhe casuali e lunghe per la sicurezza
JWT_SECRET=una_chiave_segreta_molto_lunga_e_casuale
REFRESH_TOKEN_SECRET=un_altra_chiave_segreta_per_i_refresh_token

# ── Server Configuration ──────────────────────────────────
PORT=3002

# Intervallo di sincronizzazione da Gluroo (in secondi)
POLL_INTERVAL_SECONDS=15

# URL base dell'applicazione per i link nelle email (es. recupero password).
# Se usi il backend per servire il frontend, usa il tuo dominio pubblico.
FRONTEND_URL=http://example.com

# ── Email (Resend API) ───────────────────────────────────
# Ottieni la tua API Key su https://resend.com
RESEND_API_KEY=re_123456789abc

# Mittente autorizzato. 
# NOTA: Se non hai ancora verificato il dominio su Resend, DEVI usare "onboarding@resend.dev"
# Una volta verificato il dominio (es. glicechart.ghibiri.it), puoi usare il tuo indirizzo.
EMAIL_FROM="GliceChart" <noreply@example.com>

# ── Node Environment ──────────────────────────────────────
NODE_ENV=production
